    def _vectorize(self, texts: List[str]) -> np.ndarray:
        """Simple TF-IDF vectorization."""
        from collections import Counter
        import math

        # Build vocabulary
        vocab = {}
        for text in texts:
            for word in self._tokenize(text):
                vocab.setdefault(word, len(vocab))

        # TF-IDF
        vectors = []
        doc_freq = Counter()
        tokenized = [self._tokenize(t) for t in texts]

        for tokens in tokenized:
            for word in set(tokens):
                doc_freq[word] += 1

        n_docs = len(texts)
        for tokens in tokenized:
            tf = Counter(tokens)
            vec = np.zeros(len(vocab))
            for word, count in tf.items():
                if word in vocab:
                    idf = math.log((n_docs + 1) / (doc_freq[word] + 1)) + 1
                    vec[vocab[word]] = (count / len(tokens)) * idf
            norm = np.linalg.norm(vec)
            vectors.append(vec / norm if norm > 0 else vec)

        return np.array(vectors) if vectors else np.zeros((0, len(vocab)))

    def _tokenize(self, text: str) -> List[str]:
        """Simple tokenizer."""
        import re
        text = text.lower()
        return re.findall(r'\b[a-zA-Z]{2,}\b', text)

    def add_document(self, doc: Dict):
        """Add a document to the store."""
        self.documents.append(doc)
        # Reset matrix to force rebuild on next search
        self.tfidf_matrix = None

    def search(self, query: str, top_k: int = 3) -> List[Tuple[Dict, float]]:
        """Search for similar documents."""
        if not self.documents:
            return []

        # Build text corpus
        corpus = []
        for doc in self.documents:
            text = f"{doc.get('question', '')} {doc.get('answer', '')} {doc.get('category', '')}"
            corpus.append(text)

        corpus.append(query)

        # Vectorize
        matrix = self._vectorize(corpus)
        if matrix.shape[0] < 2:
            return []

        query_vec = matrix[-1]
        doc_vecs = matrix[:-1]

        # Cosine similarity
        similarities = np.dot(doc_vecs, query_vec)
        top_indices = np.argsort(similarities)[::-1][:top_k]

        results = []
        for idx in top_indices:
            if similarities[idx] > 0.05:
                results.append((self.documents[idx], float(similarities[idx])))
        return results

    def size(self) -> int:
        return len(self.documents)




class MedBotEngine:
    """
    Main chatbot engine combining:
    - RAG with vector store
    - Anthropic Claude API
    - Sentiment-aware prompting
    - Medical entity context injection
    """

    SYSTEM_PROMPT = """You are MedBot Pro, a specialized medical AI assistant with access to a curated knowledge base of medical Q&A pairs, clinical guidelines, and research papers.

Your role:
1. Provide accurate, evidence-based medical information
2. Acknowledge when questions are outside your knowledge base
3. Always recommend consulting healthcare professionals for personal medical decisions
4. Adjust your tone based on the user's emotional state (provided as sentiment context)
5. Use clear, accessible language while being medically precise

IMPORTANT GUIDELINES:
- For emergency symptoms (chest pain, difficulty breathing, stroke signs), ALWAYS recommend calling emergency services
- Never provide specific diagnoses for individual patients
- Cite sources when possible
- Be empathetic and supportive, especially for sensitive topics

Sentiment context: {sentiment_context}
Relevant knowledge base excerpts:
{kb_context}
Medical entities detected: {entities}
"""

    def __init__(self):
        self.vector_store = SimpleVectorStore()
        self.conversation_history = []
        self.api_key = os.environ.get("ANTHROPIC_API_KEY", "")

    def _build_context(self, results: List[Tuple[Dict, float]]) -> str:
        """Format retrieved documents as context."""
        if not results:
            return "No highly relevant documents found in knowledge base."
        ctx = ""
        for i, (doc, score) in enumerate(results, 1):
            ctx += f"\n[Source {i}: {doc.get('source','Unknown')} — {doc.get('category','General')} (relevance: {score:.2f})]\n"
            ctx += f"Q: {doc.get('question','')}\nA: {doc.get('answer','')}\n"
        return ctx

    def _build_sentiment_context(self, sentiment: Dict) -> str:
        """Map sentiment to response guidance."""
        label = sentiment.get("label", "neutral").lower()
        score = sentiment.get("score", 0.5)
        mapping = {
            "negative": (
                f"The user appears distressed or concerned (confidence: {score:.0%}). "
                "Be extra empathetic, reassuring, and supportive. Acknowledge their feelings first."
            ),
            "positive": (
                f"The user seems calm and positive (confidence: {score:.0%}). "
                "Match their energy with informative, clear responses."
            ),
            "neutral": (
                "The user has a neutral, informational tone. "
                "Provide clear, factual, professional responses."
            ),
        }
        return mapping.get(label, mapping["neutral"])

    def answer(
        self,
        query: str,
        sentiment: Dict = None,
        entities: List[Dict] = None,
        threshold: float = 0.5
    ) -> Tuple[str, List[str], float]:
        """
        Generate an answer using RAG + Claude API.
        Returns: (response_text, sources, confidence)
        """
        # Retrieve relevant documents
        results = self.vector_store.search(query, top_k=3)
        filtered = [(doc, score) for doc, score in results if score >= threshold * 0.3]

        kb_context = self._build_context(filtered if filtered else results[:2])
        sources = [f"{doc.get('source','?')}: {doc.get('category','General')}"
                   for doc, _ in (filtered or results)[:3]]
        confidence = results[0][1] if results else 0.0

        # Build sentiment context
        sentiment_ctx = self._build_sentiment_context(sentiment or {})
        entity_str = ", ".join(
            f"{e['text']}({e['type']})" for e in (entities or [])
        ) or "None detected"

        system = self.SYSTEM_PROMPT.format(
            sentiment_context=sentiment_ctx,
            kb_context=kb_context,
            entities=entity_str
        )

       
        try:
            response_text = self._call_claude(query, system)
        except Exception as e:
            # Fallback: use retrieved KB answer directly
            response_text = self._fallback_response(query, filtered or results, sentiment)

        return response_text, sources, confidence

    def _call_claude(self, query: str, system: str) -> str:
        """Call Anthropic API."""
        import urllib.request
        import json

        if not self.api_key:
            raise ValueError("No API key")

        payload = {
            "model": "claude-sonnet-4-20250514",
            "max_tokens": 800,
            "system": system,
            "messages": [
                *self.conversation_history[-6:],  # last 3 turns
                {"role": "user", "content": query}
            ]
        }

        req = urllib.request.Request(
            "https://api.anthropic.com/v1/messages",
            data=json.dumps(payload).encode(),
            headers={
                "Content-Type": "application/json",
                "x-api-key": self.api_key,
                "anthropic-version": "2023-06-01"
            }
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read())
        text = data["content"][0]["text"]

       
        self.conversation_history.append({"role": "user", "content": query})
        self.conversation_history.append({"role": "assistant", "content": text})
        return text

    def _fallback_response(
        self, query: str, results: List[Tuple[Dict, float]], sentiment: Dict
    ) -> str:
        """Rule-based fallback when API is unavailable."""
        label = (sentiment or {}).get("label", "neutral")
        prefix = {
            "negative": "I understand this may be a concerning topic. ",
            "positive": "Great question! ",
            "neutral": ""
        }.get(label, "")

        if results:
            top_doc, score = results[0]
            answer = top_doc.get("answer", "")
            src = top_doc.get("source", "Medical Database")
            return (
                f"{prefix}Based on my knowledge base ({src}):\n\n{answer}\n\n"
                f"*Confidence: {score:.0%} — Always consult a healthcare professional "
                f"for personal medical advice.*"
            )
        return (
            f"{prefix}I don't have specific information about this in my current "
            "knowledge base. Please consult a qualified healthcare professional "
            "or visit reputable sources like Mayo Clinic, WebMD, or your doctor."
        )

    def search_papers(
        self, query: str, domain: str = "All", max_results: int = 5
    ) -> List[Dict]:
        """Search ArXiv papers via their API."""
        import urllib.request
        import urllib.parse

        domain_map = {
            "Computer Science": "cs",
            "Biology": "q-bio",
            "Medicine": "q-bio.QM",
            "Statistics": "stat",
            "All": ""
        }
        cat = domain_map.get(domain, "")
        search_q = f"{query} {f'cat:{cat}' if cat else ''}".strip()

        url = (
            "https://export.arxiv.org/api/query?"
            + urllib.parse.urlencode({
                "search_query": f"all:{search_q}",
                "start": 0,
                "max_results": max_results,
                "sortBy": "relevance"
            })
        )

        try:
            with urllib.request.urlopen(url, timeout=10) as resp:
                content = resp.read().decode()
            return self._parse_arxiv(content)
        except Exception:
            # Return mock data if network unavailable
            return [
                {
                    "id": "mock_001",
                    "title": f"Deep Learning Applications in {query.title()}",
                    "authors": "Smith J, Doe A, et al.",
                    "published": "2024-03",
                    "abstract": f"This paper explores {query} using state-of-the-art neural network architectures...",
                    "url": "https://arxiv.org"
                }
            ]

    def _parse_arxiv(self, xml_content: str) -> List[Dict]:
        """Parse ArXiv API XML response."""
        import re
        papers = []
        entries = re.findall(r'<entry>(.*?)</entry>', xml_content, re.DOTALL)
        for entry in entries:
            def extract(tag):
                m = re.search(rf'<{tag}[^>]*>(.*?)</{tag}>', entry, re.DOTALL)
                return m.group(1).strip() if m else ""

            authors = re.findall(r'<name>(.*?)</name>', entry)
            papers.append({
                "id": extract("id"),
                "title": extract("title").replace("\n", " "),
                "authors": ", ".join(authors[:3]) + (" et al." if len(authors) > 3 else ""),
                "published": extract("published")[:7],
                "abstract": extract("summary").replace("\n", " ")[:500],
                "url": extract("id")
            })
        return papers

    def add_document(self, doc: Dict):
        """Add a document to the vector store."""
        self.vector_store.add_document(doc)

    def kb_size(self) -> int:
        return self.vector_store.size()

