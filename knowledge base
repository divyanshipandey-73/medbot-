from datetime import datetime
from typing import Dict, List, Tuple, Optional
from pathlib import Path


class PubMedFetcher:
    """Fetch recent articles from PubMed via E-utilities API (free, no key needed)."""

    BASE_URL = "https://eutils.ncbi.nlm.nih.gov/entrez/eutils"
    SEARCH_TERMS = [
        "clinical guidelines treatment",
        "disease symptoms diagnosis",
        "drug therapy adverse effects",
        "COVID-19 treatment 2024",
        "cancer immunotherapy"
    ]

    def fetch(self, max_articles: int = 10) -> List[Dict]:
        """Fetch recent PubMed articles."""
        import urllib.request
        import urllib.parse

        articles = []
        for term in self.SEARCH_TERMS[:2]:
            try:
                # Search for IDs
                search_url = (
                    f"{self.BASE_URL}/esearch.fcgi?"
                    + urllib.parse.urlencode({
                        "db": "pubmed",
                        "term": term,
                        "retmax": 3,
                        "retmode": "json",
                        "sort": "relevance",
                        "datetype": "pdat",
                        "reldate": 365  # last year
                    })
                )
                with urllib.request.urlopen(search_url, timeout=8) as r:
                    search_data = json.loads(r.read())

                ids = search_data.get("esearchresult", {}).get("idlist", [])
                if not ids:
                    continue

                # Fetch summaries
                summary_url = (
                    f"{self.BASE_URL}/esummary.fcgi?"
                    + urllib.parse.urlencode({
                        "db": "pubmed",
                        "id": ",".join(ids),
                        "retmode": "json"
                    })
                )
                with urllib.request.urlopen(summary_url, timeout=8) as r:
                    summary_data = json.loads(r.read())

                for uid in ids:
                    doc_data = summary_data.get("result", {}).get(uid, {})
                    if doc_data:
                        title = doc_data.get("title", "")
                        authors = doc_data.get("authors", [])
                        pubdate = doc_data.get("pubdate", "")
                        source = doc_data.get("source", "PubMed")

                        articles.append({
                            "id": f"pubmed_{uid}",
                            "source": "PubMed",
                            "category": self._classify(title),
                            "question": f"What does research say about: {title[:100]}?",
                            "answer": (
                                f"Recent research published in {source} ({pubdate}) by "
                                f"{authors[0].get('name', 'et al.') if authors else 'researchers'} "
                                f"investigated: {title}. This represents current evidence in the field. "
                                f"Consult the full article for detailed findings and methodology."
                            ),
                            "metadata": {
                                "pmid": uid,
                                "journal": source,
                                "pubdate": pubdate,
                                "url": f"https://pubmed.ncbi.nlm.nih.gov/{uid}/"
                            }
                        })
            except Exception:
                continue  # Network unavailable

        return articles[:max_articles]

    def _classify(self, title: str) -> str:
        """Classify article by title keywords."""
        title_lower = title.lower()
        categories = {
            "Oncology": ["cancer", "tumor", "malignant", "chemotherapy", "immunotherapy"],
            "Cardiology": ["heart", "cardiac", "cardiovascular", "hypertension"],
            "Neurology": ["brain", "neurological", "alzheimer", "parkinson", "stroke"],
            "Infectious Disease": ["infection", "virus", "bacterial", "covid", "pathogen"],
            "Pharmacology": ["drug", "medication", "therapy", "treatment", "dose"],
            "Diabetes": ["diabetes", "insulin", "glucose", "glycemic"],
        }
        for category, keywords in categories.items():
            if any(kw in title_lower for kw in keywords):
                return category
        return "General Medicine"


