class KnowledgeBaseUpdater:
    """
    Orchestrates periodic knowledge base updates from multiple sources.
    Implements deduplication, validation, and scheduling.
    """

    def __init__(self, kb_path: str = "/tmp/medbot_kb_state.json"):
        self.kb_path = Path(kb_path)
        self.seen_ids: set = set()
        self.total_docs: int = 12  # pre-seeded
        self.update_history: List[Dict] = []
        self._load_state()

        self.fetchers = {
            "MedQuAD Dataset": MedQuADFetcher(),
            "PubMed RSS": PubMedFetcher(),
            "WHO Updates": WHOFetcher(),
        }

    def _load_state(self):
        """Load persisted state."""
        if self.kb_path.exists():
            try:
                state = json.loads(self.kb_path.read_text())
                self.seen_ids = set(state.get("seen_ids", []))
                self.total_docs = state.get("total_docs", self.total_docs)
                self.update_history = state.get("update_history", [])
            except Exception:
                pass

    def _save_state(self):
        """Persist state."""
        try:
            state = {
                "seen_ids": list(self.seen_ids),
                "total_docs": self.total_docs,
                "update_history": self.update_history[-50:],
                "last_saved": datetime.now().isoformat()
            }
            self.kb_path.write_text(json.dumps(state, indent=2))
        except Exception:
            pass

    def _validate_document(self, doc: Dict) -> Tuple[bool, str]:
        """Validate a document before adding."""
        if not doc.get("question") or len(doc["question"]) < 10:
            return False, "Question too short or missing"
        if not doc.get("answer") or len(doc["answer"]) < 20:
            return False, "Answer too short or missing"
        if not doc.get("source"):
            return False, "Source missing"
        return True, "OK"

    def _deduplicate(self, docs: List[Dict]) -> List[Dict]:
        """Remove documents already in the knowledge base."""
        new_docs = []
        for doc in docs:
            doc_id = doc.get("id") or hashlib.md5(
                (doc.get("question", "") + doc.get("answer", "")).encode()
            ).hexdigest()
            doc["id"] = doc_id
            if doc_id not in self.seen_ids:
                new_docs.append(doc)
        return new_docs

    def update(self, selected_sources: List[str]) -> Tuple[List[str], Dict]:
        """
        Run knowledge base update from selected sources.
        Returns: (log_messages, stats_dict)
        """
        logs = []
        timestamp = datetime.now().strftime("%H:%M:%S")
        new_docs_count = 0
        all_new_docs = []

        logs.append(f"[{timestamp}] Starting KB update...")

        for source_name in selected_sources:
            fetcher = self.fetchers.get(source_name)
            if not fetcher:
                logs.append(f"[{timestamp}] ⚠ No fetcher for: {source_name}")
                continue

            logs.append(f"[{timestamp}] Fetching from {source_name}...")
            try:
                raw_docs = fetcher.fetch()
                valid_docs = []
                for doc in raw_docs:
                    ok, reason = self._validate_document(doc)
                    if ok:
                        valid_docs.append(doc)
                    else:
                        logs.append(f"[{timestamp}] ✗ Skipped doc: {reason}")

                new_docs = self._deduplicate(valid_docs)
                all_new_docs.extend(new_docs)
                for doc in new_docs:
                    self.seen_ids.add(doc["id"])

                logs.append(
                    f"[{timestamp}] ✓ {source_name}: {len(new_docs)} new / "
                    f"{len(raw_docs)} total fetched"
                )
                new_docs_count += len(new_docs)

            except Exception as e:
                logs.append(f"[{timestamp}] ✗ Error fetching {source_name}: {str(e)[:50]}")

        self.total_docs += new_docs_count
        self.update_history.append({
            "timestamp": timestamp,
            "sources": selected_sources,
            "new_docs": new_docs_count,
            "total_docs": self.total_docs
        })
        self._save_state()

        logs.append(f"[{timestamp}] ✅ Update complete. +{new_docs_count} docs. Total: {self.total_docs}")

        stats = {
            "total_docs": self.total_docs,
            "new_docs": new_docs_count,
            "last_updated": datetime.now().strftime("%Y-%m-%d %H:%M"),
            "sources": selected_sources,
            "documents": all_new_docs  # For injection into chatbot engine
        }
        return logs, stats

    def get_schedule_info(self, interval: str) -> str:
        """Return human-readable schedule info."""
        intervals = {
            "Every hour": "Updates run every 60 minutes",
            "Every 6 hours": "Updates run 4 times daily",
            "Daily": "Updates run once at midnight",
            "Manual": "Manual updates only"
        }
        return intervals.get(interval, "Manual updates only")

    def get_update_history(self) -> List[Dict]:
        return self.update_history

